# Keep Docker build context small. The repo is ~5GB without this — most of
# that is .git, node_modules, and test fixtures that the Dockerfiles never
# need. Source-build Dockerfiles still get all of pkg/, internal/, cmd/,
# public/, platform/vigolium-audit, platform/jstangle, Makefile, go.mod, go.sum.

# Git metadata (Makefile gracefully falls back to commit="unknown")
.git/
.gitignore
.gitattributes

# Node module trees — rebuilt inside the container by `bun install`
**/node_modules/

# Compiled JS/TS dist trees — `bun run build` rebuilds them. Keep the Linux
# vigolium-audit blobs in the Docker context so multi-arch builds can stage the
# correct target blob instead of rebuilding the audit package under QEMU.
platform/*/build/dist/
!platform/vigolium-audit/build/dist/
!platform/vigolium-audit/build/dist/vigolium-audit-linux-arm64
!platform/vigolium-audit/build/dist/vigolium-audit-linux-x64
platform/*/dist/

# The embedded vigolium-audit blob is a SINGLE host-arch-specific file consumed
# by go:embed. Keep the build-host's copy out of the context; Docker stages the
# correct Linux blob from platform/vigolium-audit/build/dist/ per target arch.
pkg/audit/bin/_bin/vigolium-audit

# Test fixtures (large, not needed for build)
test/testdata/

# Local build outputs
bin/
build/dist/
build/dist-public/
# Stray dev binary at the repo root (~280MB) — built by `go build`/IDE runs,
# never needed in the image (the Dockerfile compiles its own). Anchored to root
# so it can't match cmd/vigolium or other paths.
/vigolium
/vigolium-prod

# Editor / OS noise
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# Logs and local state
*.log
.vigolium/
sessions/

# Docker files themselves (already on the daemon)
build/Dockerfile
build/Dockerfile.minimal
build/Dockerfile.prod
.dockerignore
