# Vigolium — managed by Ansible
# TLS via Cloudflare DNS-01 challenge (no port 80 needed for ACME)

{{ vigolium_domain }} {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}

	# Proxy everything to Next.js console (cloud mode)
	# Next.js handles /api/proxy/* → Vigolium scanner server internally
	reverse_proxy localhost:{{ vigolium_console_port }} {
		# WebSocket support for HMR / live features
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}
	}

	# Health check endpoint (bypass Next.js, go direct to scanner)
	handle /health {
		reverse_proxy {{ vigolium_server_host }}:{{ vigolium_server_port }}
	}

	# Compress responses
	encode gzip zstd

	# Access logs
	log {
		output file /var/log/caddy/access.log {
			roll_size 100mb
			roll_keep 5
		}
	}
}
