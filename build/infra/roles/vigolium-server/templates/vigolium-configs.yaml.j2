# Vigolium Configuration — managed by Ansible
# {{ ansible_date_time.iso8601 }}

server:
  auth_api_key: "{{ vigolium_api_key }}"
  service_port: {{ vigolium_server_port }}
  cors_allowed_origins: "reflect-origin"
  enable_metrics: true

database:
  enabled: true
  driver: sqlite
  sqlite:
    path: {{ vigolium_db_path }}
    busy_timeout: 15000
    journal_mode: WAL
    synchronous: NORMAL
    cache_size: 10000

scanning_strategy:
  default_strategy: 'balanced'

scanning_pace:
  concurrency: {{ vigolium_concurrency }}
  rate_limit: {{ vigolium_rate_limit }}
  max_per_host: {{ vigolium_max_per_host }}
  max_duration: {{ vigolium_max_duration }}

oast:
  enabled: true

audit:
  max_findings_per_module: 15
  extensions:
    enabled: false
    extension_dir: {{ vigolium_data_dir }}/extensions/
