# Vigolium Console .env — place your real values in console.env
# Encrypt with: ansible-vault encrypt console.env
#
# VIGOLIUM_SCAN_SERVER and VIGOLIUM_AUTH_API_KEY are injected by Ansible
# from group_vars — you don't need to set them here.

# WorkOS AuthKit
WORKOS_API_KEY=sk_test_...
WORKOS_CLIENT_ID=client_...
WORKOS_COOKIE_PASSWORD=your-32-char-random-string-here!!
NEXT_PUBLIC_WORKOS_REDIRECT_URI=https://scan.example.com/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# GitHub OAuth
GITHUB_CLIENT_ID=Iv1.xxxxx
GITHUB_CLIENT_SECRET=xxxxx

# Auth bypass (set true to skip WorkOS/Stripe entirely)
VIGOLIUM_SKIP_AUTH=false
