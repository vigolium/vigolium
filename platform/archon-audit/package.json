{
  "name": "archon",
  "version": "0.1.4-alpha",
  "description": "Archon — autonomous agent that performs thorough security audits on your codebase, part of Vigolium",
  "keywords": [
    "vigolium",
    "security-audit",
    "codex",
    "claude",
    "claude-code",
    "agent-sdk",
    "anthropic",
    "openai"
  ],
  "license": "AGPL-3.0-only",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "archon-audit": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run build.ts",
    "build:all": "bun run build.ts --all",
    "transform": "bun run scripts/transform-content.ts",
    "release": "bun run scripts/release.ts",
    "release:dry": "ARCHON_RELEASE_DRY_RUN=1 bun run scripts/release.ts",
    "npm-publish": "bun run scripts/npm-publish.ts",
    "npm-publish:dry": "ARCHON_NPM_DRY_RUN=1 bun run scripts/npm-publish.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.138",
    "@openai/codex-sdk": "^0.130.0",
    "cac": "^6.7.14",
    "chalk": "^5.3.0",
    "yaml": "^2.6.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
