{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/settings/layout,_N_T_/settings/[[...tab]]/layout,_N_T_/settings/[[...tab]]/page,_N_T_/settings/about"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/settings/$oc$tab/__PAGE__",
    "/settings/$oc$tab",
    "/settings",
    "/_index",
    "/_head"
  ]
}