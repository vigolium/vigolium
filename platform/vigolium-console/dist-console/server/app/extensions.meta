{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/extensions/layout,_N_T_/extensions/page,_N_T_/extensions"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/extensions/__PAGE__",
    "/extensions",
    "/_index",
    "/_head"
  ]
}