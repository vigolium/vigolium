# Vigolium Console — Server-side configuration
# Copy this file to .env and fill in the values.
# These variables are server-side only and never exposed to the browser.

# ---------------------------------------------------------------------------
# Vigolium Scan Server
# ---------------------------------------------------------------------------
VIGOLIUM_SCAN_SERVER=http://localhost:9002

# API key for authenticating with the scan server.
# Obtain it by running:
#   vigolium config view server.auth_api_key --force | awk '{print $3}'
VIGOLIUM_AUTH_API_KEY=

# ---------------------------------------------------------------------------
# WorkOS AuthKit  (https://workos.com/docs/user-management)
# ---------------------------------------------------------------------------
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=           # 32+ character random string for encrypting session cookie
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:5002/callback

# ---------------------------------------------------------------------------
# Stripe  (https://stripe.com/docs)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=                # sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=            # whsec_... (from Stripe webhook endpoint)

# ---------------------------------------------------------------------------
# GitHub OAuth  (https://docs.github.com/en/apps/oauth-apps)
# ---------------------------------------------------------------------------
GITHUB_CLIENT_ID=               # GitHub OAuth App client ID
GITHUB_CLIENT_SECRET=           # GitHub OAuth App client secret

# ---------------------------------------------------------------------------
# Access Code Auth  (optional — enables access code login alongside WorkOS)
# ---------------------------------------------------------------------------
CONSOLE_USERS_PATH=               # Path to console-users.json (default: config/console-users.json)
ACCESS_SESSION_SECRET=            # Secret for signing access-code cookies (defaults to WORKOS_COOKIE_PASSWORD)
REQUIRE_ORG_MEMBERSHIP=false      # Require WorkOS org membership to access platform

# ---------------------------------------------------------------------------
# SSO control
# ---------------------------------------------------------------------------
# Set to true to disable SSO (WorkOS) login and default to access-code login.
# SSO is also auto-disabled when WORKOS_API_KEY or WORKOS_CLIENT_ID are missing.
VIGOLIUM_DISABLE_SSO=false

# ---------------------------------------------------------------------------
# Auth bypass
# ---------------------------------------------------------------------------
# Set to true to skip authentication and billing entirely (development / self-hosted)
VIGOLIUM_SKIP_AUTH=false

# ---------------------------------------------------------------------------
# Showcases  (public scan report gallery)
# ---------------------------------------------------------------------------
# Enable the /showcases listing page
VIGOLIUM_SHOWCASES_ENABLED=false
# Secret key required as ?view_key= to access individual reports
VIGOLIUM_SHOWCASES_KEY=
