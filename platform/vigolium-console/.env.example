# Vigolium Console — Server-side configuration
# Copy this file to .env and fill in the values.
# These variables are server-side only and never exposed to the browser.

# ---------------------------------------------------------------------------
# Vigolium Scan Server
# ---------------------------------------------------------------------------
VIGOLIUM_SCAN_SERVER=http://localhost:9002

# API key for authenticating with the scan server.
# Obtain it by running:
#   vigolium config view server.auth_api_key --force | awk '{print $3}'
VIGOLIUM_AUTH_API_KEY=

# ---------------------------------------------------------------------------
# WorkOS AuthKit  (https://workos.com/docs/user-management)
# ---------------------------------------------------------------------------
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=           # 32+ character random string for encrypting session cookie
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:5002/callback

# ---------------------------------------------------------------------------
# Stripe  (https://stripe.com/docs)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=                # sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=            # whsec_... (from Stripe webhook endpoint)

# ---------------------------------------------------------------------------
# GitHub App  (https://docs.github.com/en/apps)
# ---------------------------------------------------------------------------
GITHUB_APP_ID=                  # GitHub App ID (numeric)
GITHUB_APP_SLUG=                # GitHub App URL slug (e.g., my-vigolium-app)
GITHUB_PRIVATE_KEY=             # PEM private key (use \n for newlines in single-line format)

# ---------------------------------------------------------------------------
# Auth bypass
# ---------------------------------------------------------------------------
# Set to true to skip authentication and billing entirely (development / self-hosted)
VIGOLIUM_SKIP_AUTH=false
