run:
  queries:
   -
    pack: harbor/security-queries#3
    relativeQueryPath: MissingRequireProjectAccess.ql
    relativeBqrsPath: harbor/security-queries/MissingRequireProjectAccess.bqrs
    metadata:
      name: Missing RequireProjectAccess in v2.0 API handler
      description: |-
        Handler methods that do not call RequireProjectAccess,
                      RequireSystemAccess, or RequireAuthenticated before performing
                      operations on resources. This is the root-cause pattern behind
                      CVE-2022-31666 through CVE-2022-31671 (authorization bypass).
      kind: problem
      id: harbor/missing-require-project-access
      problem.severity: error
      security-severity: 9.1
      tags: |-
        security
               authorization
               harbor
